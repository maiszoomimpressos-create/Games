# Copie este arquivo para TRILHA/.env e preencha com os valores do painel:
# Supabase → Project Settings → API

# Project URL (mesmo valor nas duas linhas abaixo e em VITE_SUPABASE_URL)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Project API keys → bloco "anon" / "public" (JWT longo; NÃO use service_role no front)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mesmos valores — o Vite só expõe variáveis com prefixo VITE_
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API (opcional)
# PORT=3001
# CORS_ORIGIN=http://localhost:5173

# Testes multiplayer (Studio → Testes → Ambiente real):
# 1) supabase/migrations/004_trilha_live_games.sql
# 2) supabase/migrations/005_trilha_join_rpc_jsonb.sql (corrige RPC se aparecer erro "schema cache")
# Realtime na tabela trilha_live_games.
